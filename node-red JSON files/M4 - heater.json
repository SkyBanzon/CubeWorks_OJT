    {
        "id": "136ce45db9ff6158",
        "type": "function",
        "z": "f732b9552566a35c",
        "name": "Heating Sequence",
        "func": "if (msg.payload !== true) return null;\n\nlet timerDuration = flow.get(\"treatment_time\") || 5;\n\nlet stopBelt = { payload: false };\nlet startHeater = { payload: true };\nlet startTrigger = { payload: true };\nlet dbLog = {\n    payload: {},\n    params: [timerDuration]\n};\n\nnode.send([stopBelt, startHeater, startTrigger, dbLog]);\n\nsetTimeout(function () {\n    let startBelt = { payload: true };\n    let stopHeater = { payload: false };\n    node.send([startBelt, stopHeater, null, null]);\n    node.done();\n}, timerDuration * 1000);\n\nreturn null;",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
