        "format": "<div style=\"display:flex; justify-content:center; align-items:center; gap:20px; padding:20px;\">\n\n    <!-- Traffic Light -->\n    <div\n        style=\"background:dimgray; padding:15px; border-radius:10px; display:flex; flex-direction:column; align-items:center; gap:10px;\">\n        <div id=\"redlite\"\n            style=\"width:80px; height:80px; border-radius:50%; background:#440000; border:2px solid black; transition: background 0.3s ease;\">\n        </div>\n        <div id=\"yellowlite\"\n            style=\"width:80px; height:80px; border-radius:50%; background:#444400; border:2px solid black; transition: background 0.3s ease;\">\n        </div>\n        <div id=\"greenlite\"\n            style=\"width:80px; height:80px; border-radius:50%; background:#004400; border:2px solid black; transition: background 0.3s ease;\">\n        </div>\n    </div>\n\n    <!-- Countdown Timer -->\n    <div style=\"background:dimgray; padding:20px; border-radius:10px;\">\n        <span id=\"texttimer\" style=\"font-family:Arial Black; font-size:80px; color:red;\">00</span>\n    </div>\n\n</div>\n\n<script>\n    (function() {\n    scope.$watch('msg', function(msg) {\n        if (!msg) return;\n        \n        document.getElementById(\"redlite\").style.background = msg.redFill;\n        document.getElementById(\"yellowlite\").style.background = msg.yellowFill;\n        document.getElementById(\"greenlite\").style.background = msg.greenFill;\n        document.getElementById(\"texttimer\").style.color = msg.textColor;\n        document.getElementById(\"texttimer\").textContent = msg.countdown;\n    });\n})();\n</script>",
