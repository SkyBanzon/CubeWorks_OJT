    {
        "id": "73e66a9f4191456d",
        "type": "function",
        "z": "f732b9552566a35c",
        "name": "countdown",
        "func": "// 1. Clear any existing timer already running on this node\nlet oldCounter = context.get('counter');\nif (oldCounter) {\n    clearInterval(oldCounter);\n}\n\n// 2. Only start counting if we receive a 'true' trigger\nif (msg.payload === true) {\n    let timeLeft = flow.get(\"treatment_time\") || 5;\n\n    // Send the starting number to the gauge\n    node.send({ payload: timeLeft });\n\n    // 3. Start the new timer\n    let counter = setInterval(function() {\n        timeLeft--;\n        \n        if (timeLeft <= 0) {\n            clearInterval(counter);\n            context.set('counter', null); // Clean up context\n            node.send({ payload: 0 });\n        } else {\n            node.send({ payload: timeLeft });\n        }\n    }, 1000);\n\n    // 4. Save the timer ID so we can kill it if a new box arrives early\n    context.set('counter', counter);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1570,
