    {
        "id": "c763c5cce8ac8b39",
        "type": "function",
        "z": "f732b9552566a35c",
        "name": "split data",
        "func": "// Output 1 -> Chart\nlet chartData = [{\n    \"series\": [\"Cooking Time\"],\n    \"data\": [msg.payload.map(row => ({\n        \"x\": new Date(row.timestamp).getTime(),  // Chart needs ms epoch\n        \"y\": Number(row.value)\n    })).reverse()]\n}];\n\n// Output 2 -> \"# of Items Heated\" Text Node\nlet totalCount = msg.payload.length > 0 ? msg.payload[0].total_count : 0;\n\nreturn [\n    { payload: chartData },\n    { payload: String(totalCount) }\n];",
