    {
        "id": "3ff92ad56d71d860",
        "type": "function",
        "z": "984cca2f7cf461b2",
        "name": "Chart Format",
        "func": "let data = msg.payload;\nlet totalCount = 0;\n\n// Format for Chart (Output 1)\nlet chartData = {\n    \"series\": [\"Materials\"],\n    \"data\": [[]],\n    \"labels\": []\n};\n\ndata.forEach(row => {\n    let count = parseInt(row.total);\n    chartData.labels.push(row.material_type);\n    chartData.data[0].push(count);\n    totalCount += count; // Calculate the sum here\n});\n\n// Output 1 goes to Chart, Output 2 goes to Gauge\nreturn [{ payload: [chartData] }, { payload: totalCount }];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 920,
        "wires": [
