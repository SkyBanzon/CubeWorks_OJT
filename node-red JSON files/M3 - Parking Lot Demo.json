    {
        "id": "38013ad1cb230849",
        "type": "function",
        "z": "6d87f9c445c79ce1",
        "name": "Auto-Stop",
        "func": "// Check if the signal is from the Exit Button\nif (msg.topic === \"release_button\" && msg.payload === true) {\n    return { payload: true }; // Start the belt\n}\n\n// Check if the signal is from the Exit Sensor (Looking at Array Index 0)\nif (msg.topic === \"exit_sensor\") {\n    // We check if payload is an array and if the first item is true\n    if (Array.isArray(msg.payload) && msg.payload[0] === true) {\n        return { payload: false }; // STOP the belt\n    } \n    // If you fixed the switch node to send a single boolean instead:\n    else if (msg.payload === true) {\n        return { payload: false }; // STOP the belt\n    }\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1240,
        "y": 520,
        "wires": [
            [
                "179d08acd95c8572",
                "58bbbc4643245fb9"
            ]
        ]
