        "name": "read count from db",
        "query": "SELECT \n  (SELECT COUNT(*) FROM occupancy_logs WHERE event_type = 'Entry') - \n  (SELECT COUNT(*) FROM occupancy_logs WHERE event_type = 'Exit') \nAS total;",
