        "name": "poll data",
        "query": "SELECT \n    process_duration_sec AS value, \n    log_time AS timestamp,\n    (SELECT COUNT(*) FROM treatment_logs) AS total_count\nFROM treatment_logs \nORDER BY log_time DESC \nLIMIT 10;",
