    {
        "id": "a03bea43a100fa36",
        "type": "function",
        "z": "984cca2f7cf461b2",
        "name": "Sort & Log",
        "func": "// msg.payload[0-2] = Color Sensors (100, 101, 102)\n// msg.payload[3-4] = Front Limits (103, 104)\nlet inputs = msg.payload;\n\nlet blueAct = null;\nlet greenAct = null;\n\n// Pass the raw sensor state (true or false) to the filters\nlet blueLog = { payload: inputs[0] };\nlet greenLog = { payload: inputs[1] };\nlet metalLog = { payload: inputs[2] };\n\n// --- PUSHING LOGIC ---\nif (inputs[0] === true) { blueAct = { payload: true }; }\nif (inputs[1] === true) { greenAct = { payload: true }; }\n\n// --- RETRACTION LOGIC ---\nif (inputs[3] === true) { blueAct = { payload: false }; }\nif (inputs[4] === true) { greenAct = { payload: false }; }\n\nreturn [blueAct, greenAct, blueLog, greenLog, metalLog];",
        "outputs": 5,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
