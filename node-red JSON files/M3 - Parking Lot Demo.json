    {
        "id": "6a5cbaedebeebd61",
        "type": "function",
        "z": "6d87f9c445c79ce1",
        "name": "Lights",
        "func": "// Get the current count from the previous node\nlet count = msg.payload;\n\n// Define what the state SHOULD be\nlet greenState = (count < 5);\nlet yellowState = (count >= 5 && count < 9);\nlet redState = (count >= 9);\n\n// 'context' allows the node to remember what it did last time\nlet lastGreen = context.get('lastGreen') || null;\nlet lastYellow = context.get('lastYellow') || null;\nlet lastRed = context.get('lastRed') || null;\n\n// Only send a message if the state has changed\nlet green = (greenState !== lastGreen) ? { payload: greenState } : null;\nlet yellow = (yellowState !== lastYellow) ? { payload: yellowState } : null;\nlet red = (redState !== lastRed) ? { payload: redState } : null;\n\n// Save the current state for the next 1-second check\ncontext.set('lastGreen', greenState);\ncontext.set('lastYellow', yellowState);\ncontext.set('lastRed', redState);\n\nreturn [green, yellow, red];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
