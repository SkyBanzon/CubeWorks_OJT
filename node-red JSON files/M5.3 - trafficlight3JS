        "type": "function",
        "z": "080d8808c7f3ca9b",
        "name": "brain",
        "func": "// 1. INITIALIZATION\nlet state = context.get('state') || \"RED\";\nlet timer = context.get('timer') || 100;\n\n// 2. GET CONFIGURABLE DURATIONS\nlet redDur = flow.get('redDuration') || 10;\nlet greenDur = flow.get('greenDuration') || 8;\nlet yellowDur = flow.get('yellowDuration') || 3;\n\n// 3. COUNTDOWN LOGIC\ntimer--;\n//node.warn(\"timer: \" + timer + \" state: \" + state);\nlet dbMsg = null;\n\n// 4. STATE TRANSITION LOGIC\nif (timer <= 0) {\n    let prevLight = state; // Capture BEFORE changing state\n    let prevDuration = prevLight === \"RED\" ? redDur : prevLight === \"GREEN\" ? greenDur : yellowDur; // Get its duration\n\n    // Sequence: RED -> GREEN -> YELLOW -> RED\n    if (state === \"RED\") {\n        state = \"GREEN\";\n        timer = greenDur * 10;\n    } else if (state === \"GREEN\") {\n        state = \"YELLOW\";\n        timer = yellowDur * 10;\n    } else if (state === \"YELLOW\") {\n        state = \"RED\";\n        timer = redDur * 10;\n    }\n\n    // 5. DATABASE LOGGING - logs prevLight and its actual duration\n    dbMsg = {\n        payload: {},\n        params: [prevLight, prevDuration]\n    };\n}\n\n// Save context\ncontext.set('state', state);\ncontext.set('timer', timer);\n\n// 6. PREPARE OUTPUTS\n// ... [Existing countdown and transition logic] ...\nlet modbusLights = {\n    payload: [state === \"GREEN\", state === \"YELLOW\", state === \"RED\"]\n};\n\nlet modbusTimer = {\n    payload: Math.ceil(timer / 10)\n};\n\nlet activeColor = state;\nlet countdownVal = Math.ceil(timer / 10);\n\n// SVG DATA - This object drives the Binding tab\nlet uiUpdate = {\n    payload: activeColor,\n    countdown: String(countdownVal).padStart(2, '0'),\n    redFill: (activeColor === \"RED\") ? \"#FF0000\" : \"#440000\",\n    yellowFill: (activeColor === \"YELLOW\") ? \"#FFFF00\" : \"#444400\",\n    greenFill: (activeColor === \"GREEN\") ? \"#00FF00\" : \"#004400\",\n    textColor: (activeColor === \"RED\") ? \"#FF0000\" : \n               (activeColor === \"YELLOW\") ? \"#FFFF00\" : \"#00FF00\"\n};\n\n// Routing to 4 outputs: Modbus Lights, Modbus Timer, SVG Visual, DB Log\nif (dbMsg) {\n    node.send([modbusLights, modbusTimer, uiUpdate, dbMsg]);\n} else {\n    node.send([modbusLights, modbusTimer, uiUpdate, null]);\n}\nreturn null;",
