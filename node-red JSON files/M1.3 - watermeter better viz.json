    {
        "id": "06df20c32ce5a00f",
        "type": "function",
        "z": "02879a116768cda2",
        "name": "function 1",
        "func": "var tank = context.get('tank') || { level: 0, fill: 0, discharge: 0 };\n\nif (msg.topic === 'level') tank.level = parseFloat(msg.payload) || 0;\nelse if (msg.topic === 'fill') tank.fill = parseFloat(msg.payload) || 0;\nelse if (msg.topic === 'discharge') tank.discharge = parseFloat(msg.payload) || 0;\n\ncontext.set('tank', tank);\nmsg.payload = tank;\nmsg.topic = '';\nreturn msg;",
