    {
        "id": "tank_visual_template",
        "type": "ui_template",
        "z": "02879a116768cda2",
        "group": "4bf7cef26fb9a056",
        "name": "Tank Digital Twin",
        "order": 5,
        "width": "15",
        "height": "15",
        "format": "<style>\n  .twin-wrap {\n    position: relative;\n    width: 100%;\n    user-select: none;\n  }\n\n  .twin-wrap img {\n    width: 100%;\n    display: block;\n    border-radius: 6px;\n  }\n\n  .water-body {\n    position: absolute;\n    pointer-events: none;\n    overflow: visible;\n    transition: top 0.7s ease, height 0.7s ease;\n  }\n\n  .water-fill {\n    position: absolute;\n    left: 0; right: 0;\n    top: 0; bottom: 0;\n    border-radius: 0 0 50% 50% / 0 0 12px 12px;\n    overflow: hidden;\n  }\n\n  .water-top {\n    position: absolute;\n    top: -8px;\n    left: -2%;\n    right: -2%;\n    height: 16px;\n    border-radius: 50%;\n    z-index: 2;\n  }\n\n  .hud {\n    position: absolute;\n    background: rgba(8, 16, 36, 0.82);\n    border: 1px solid rgba(90, 170, 255, 0.6);\n    border-radius: 7px;\n    padding: 5px 11px 6px;\n    color: #fff;\n    font-family: 'Roboto Mono', monospace, sans-serif;\n    line-height: 1.3;\n    white-space: nowrap;\n  }\n\n  .hud-lbl {\n    font-size: 9px;\n    letter-spacing: 0.08em;\n    color: rgba(140, 200, 255, 0.85);\n    text-transform: uppercase;\n  }\n\n  .hud-val {\n    font-size: 16px;\n    font-weight: 600;\n    color: #fff;\n  }\n\n  .hud-unit {\n    font-size: 10px;\n    color: rgba(160, 210, 255, 0.75);\n    margin-left: 2px;\n  }\n</style>\n\n<div class=\"twin-wrap\">\n  <img src=\"/ui/img/tank.png\" style=\"width:100%;display:block;border-radius:6px;\" />\n\n  <!-- Water body — bottom stays at 88.5 -->\n  <div class=\"water-body\" ng-style=\"{\n    display:  (msg.payload.level / 300) < 0.01 ? 'none' : 'block',\n    left:     '32.5%',\n    width:    '32%',\n    top:      (88.5 - (msg.payload.level / 300) * (88.5 - 28)) + '%',\n    height:   ((msg.payload.level / 300) * (88.5 - 28)) + '%',\n    background: 'transparent'\n  }\">\n    <div class=\"water-fill\" ng-style=\"{background: 'rgba(28,110,185,0.45)'}\"></div>\n    <div class=\"water-top\" ng-style=\"{background: 'rgba(60,140,220,0.90)'}\"></div>\n  </div>\n\n  <!-- Tick marks — ruler bottom at 87, independent of water -->\n  <div style=\"position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;\">\n    <div style=\"position:absolute;\"\n      ng-style=\"{top: (87 - 0*(87-28)/100) + '%', left:'68%', width:'2%', height:'1px', background:'rgba(0,0,0,0.7)'}\">\n    </div>\n    <div style=\"position:absolute;font-size:8px;color:rgba(0,0,0,0.9);font-family:monospace;font-weight:bold;\"\n      ng-style=\"{top: (87 - 0*(87-28)/100) + '%', left:'71%', transform:'translateY(-50%)'}\">0</div>\n\n    <div style=\"position:absolute;\"\n      ng-style=\"{top: (87 - 25*(87-28)/100) + '%', left:'68%', width:'2%', height:'1px', background:'rgba(0,0,0,0.7)'}\">\n    </div>\n    <div style=\"position:absolute;font-size:8px;color:rgba(0,0,0,0.9);font-family:monospace;font-weight:bold;\"\n      ng-style=\"{top: (87 - 25*(87-28)/100) + '%', left:'71%', transform:'translateY(-50%)'}\">75</div>\n\n    <div style=\"position:absolute;\"\n      ng-style=\"{top: (87 - 50*(87-28)/100) + '%', left:'68%', width:'2%', height:'1px', background:'rgba(0,0,0,0.7)'}\">\n    </div>\n    <div style=\"position:absolute;font-size:8px;color:rgba(0,0,0,0.9);font-family:monospace;font-weight:bold;\"\n      ng-style=\"{top: (87 - 50*(87-28)/100) + '%', left:'71%', transform:'translateY(-50%)'}\">150</div>\n\n    <div style=\"position:absolute;\"\n      ng-style=\"{top: (87 - 75*(87-28)/100) + '%', left:'68%', width:'2%', height:'1px', background:'rgba(0,0,0,0.7)'}\">\n    </div>\n    <div style=\"position:absolute;font-size:8px;color:rgba(0,0,0,0.9);font-family:monospace;font-weight:bold;\"\n      ng-style=\"{top: (87 - 75*(87-28)/100) + '%', left:'71%', transform:'translateY(-50%)'}\">225</div>\n\n    <div style=\"position:absolute;\"\n      ng-style=\"{top: (87 - 100*(87-28)/100) + '%', left:'68%', width:'2%', height:'1px', background:'rgba(0,0,0,0.7)'}\">\n    </div>\n    <div style=\"position:absolute;font-size:8px;color:rgba(0,0,0,0.9);font-family:monospace;font-weight:bold;\"\n      ng-style=\"{top: (87 - 100*(87-28)/100) + '%', left:'71%', transform:'translateY(-50%)'}\">300</div>\n  </div>\n\n  <!-- HUDs -->\n  <div class=\"hud\" style=\"top:13%; left:33%; transform:translateX(-50%);\">\n    <div class=\"hud-lbl\">Water Level</div>\n    <div class=\"hud-val\">{{msg.payload.level | number:1}}<span class=\"hud-unit\">mm</span></div>\n  </div>\n\n  <div class=\"hud\" style=\"top:5%; right:4%;\">\n    <div class=\"hud-lbl\">Fill Valve</div>\n    <div class=\"hud-val\">{{msg.payload.fill | number:1}}<span class=\"hud-unit\">%</span></div>\n  </div>\n\n  <div class=\"hud\" style=\"bottom:14%; left:2%;\">\n    <div class=\"hud-lbl\">Discharge Valve</div>\n    <div class=\"hud-val\">{{msg.payload.discharge | number:1}}<span class=\"hud-unit\">%</span></div>\n  </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1190,
        "y": 460,
        "wires": [
            []
        ]
